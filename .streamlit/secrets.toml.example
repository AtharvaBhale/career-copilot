# Copy this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml is gitignored, never commit your actual keys.

# Required: free Groq API key for LLM (resume, cover letter, scoring)
GROQ_API_KEY = "your-groq-api-key-here"

# Optional: enables auto-backup of the SQLite file to a private GitHub repo,
# needed because Streamlit Cloud wipes local disk on restart/redeploy.
GITHUB_TOKEN = ""
GITHUB_REPO = "yourusername/career-copilot-data"
GITHUB_BRANCH = "main"

# Optional: Adzuna free tier for more US job listings (5000 calls/month)
# Register at https://developer.adzuna.com
ADZUNA_APP_ID = ""
ADZUNA_APP_KEY = ""

# Optional: Hunter.io free tier for email discovery (25 searches/month)
HUNTER_API_KEY = ""
